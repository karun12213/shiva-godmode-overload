{
  "version": 2,
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "api/*.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    { "src": "/api/status", "dest": "/api/status.py" },
    { "src": "/api/trades", "dest": "/api/trades.py" },
    { "src": "/api/log", "dest": "/api/log.py" },
    { "src": "/api/config", "dest": "/api/config.py" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
