{
  "version": 2,
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "api/*.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    { "src": "/api/status", "dest": "/api/status.py", "headers": { "Cache-Control": "no-cache" } },
    { "src": "/api/trades", "dest": "/api/trades.py", "headers": { "Cache-Control": "no-cache" } },
    { "src": "/api/log", "dest": "/api/log.py", "headers": { "Cache-Control": "no-cache" } },
    { "src": "/api/agents", "dest": "/api/agents.py", "headers": { "Cache-Control": "no-cache" } },
    { "src": "/api/config", "dest": "/api/config.py", "headers": { "Cache-Control": "no-cache" } },
    { "src": "/(.*)", "dest": "/index.html", "headers": { "Cache-Control": "no-cache, no-store, must-revalidate" } }
  ]
}
